# Banco de dados (Supabase Postgres) — Settings > Database > Connection string no painel do Supabase
# DATABASE_URL: connection string "Transaction pooler" (porta 6543) — usada em runtime pela aplicação
# DIRECT_URL: connection string "Session"/direta (porta 5432) — usada só para rodar as migrations
DATABASE_URL=
DIRECT_URL=

# Login do painel /admin via Supabase Auth — Settings > API no painel do Supabase
# NEXT_PUBLIC_SUPABASE_ANON_KEY é a chave "publishable" (pública, segura para o navegador)
# Crie os usuários administradores em Authentication > Users no painel do Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Envio de e-mail (formulário de contato + e-mails automáticos para leads) via https://resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL="ASTI Tech <contato@astitech.com.br>"

# Geração do mockup (HTML) e das ideias de conteúdo via API da Claude — console.anthropic.com
ANTHROPIC_API_KEY=

# Publicação do código-fonte gerado em um repositório privado por cliente
# GITHUB_ORG é opcional — sem ela, os repositórios são criados na conta dona do token
GITHUB_TOKEN=
GITHUB_ORG=

# URL pública do site — usada para montar o link do mockup (SITE_URL/<slug>)
SITE_URL=http://localhost:3000
