# Banco de dados (Supabase Postgres) — Settings > Database > Connection string no painel do Supabase
# DATABASE_URL: connection string "Transaction pooler" (porta 6543) — usada em runtime pela aplicação
# DIRECT_URL: connection string "Session"/direta (porta 5432) — usada só para rodar as migrations
DATABASE_URL=
DIRECT_URL=

# Senha de acesso ao painel /admin (troque em produção — sem esta variável, usa um valor padrão inseguro)
ADMIN_PASSWORD=

# Envio de e-mail (formulário de contato + e-mails automáticos para leads) via https://resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL="ASTI Tech <contato@astitech.com.br>"

# Fase 2 — geração de sites com IA (ainda não integrado)
ANTHROPIC_API_KEY=

# Fase 2 — publicação do código-fonte gerado em um repositório por cliente (ainda não integrado)
GITHUB_TOKEN=
GITHUB_ORG=
