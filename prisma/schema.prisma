generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum LeadStatus {
  novo
  coletando_dados
  gerando_site
  publicando
  pronto_para_email
  email_enviado
  respondeu_interessado
  sem_interesse
  erro
  cancelado
}

model Lead {
  id                   String     @id @default(uuid())
  sourceUrl            String
  businessName         String
  segment              String?
  contactEmail         String?
  contactPhone         String?
  status               LeadStatus @default(novo)
  estimatedMonthlyCost Float?
  siteIdeas            String[]   @default([])
  slug                 String?    @unique
  siteHtml             String?
  mockupUrl            String?
  githubRepoUrl        String?
  businessDescription  String?
  logoUrl              String?
  brandColors          String[]   @default([])
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  timeline             LeadTimelineEntry[]

  @@map("leads")
}

model LeadTimelineEntry {
  id     String   @id @default(uuid())
  leadId String
  lead   Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  at     DateTime @default(now())
  label  String
  detail String?

  @@map("lead_timeline_entries")
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String?
  business  String?
  message   String
  createdAt DateTime @default(now())

  @@map("contact_messages")
}

/// Linha única (id fixo = 1) com configurações globais do painel admin.
model AppSettings {
  id               Int      @id @default(1)
  testEmailAddress String?
  emailSubject     String?
  emailBodyHtml    String?
  autoSendEmail    Boolean  @default(true)
  updatedAt        DateTime @updatedAt

  @@map("app_settings")
}

enum JobStatus {
  pendente
  processando
  concluido
  erro
  cancelado
}

/// Job em segundo plano (ex: varredura de uma lista de anúncios), com log de
/// progresso para acompanhamento em tempo real pelo painel.
model ScanJob {
  id              String    @id @default(uuid())
  type            String
  sourceUrl       String
  status          JobStatus @default(pendente)
  candidatesFound Int?
  totalToProcess  Int?
  leadsCreated    Int       @default(0)
  errorMessage    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  log             ScanJobLogEntry[]

  @@map("scan_jobs")
}

model ScanJobLogEntry {
  id      String   @id @default(uuid())
  jobId   String
  job     ScanJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  at      DateTime @default(now())
  message String

  @@map("scan_job_log_entries")
}
